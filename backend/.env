#glm-4:Chunking and combining settings
NUMBER_OF_CHUNKS_TO_COMBINE = 5    # 5
TEXT_CHUNK_SIZE = 800              # 800 字符 ≈ 800 Token
TEXT_CHUNK_OVERLAP = 80            # 10% 重叠，避免上下文断裂
UPDATE_GRAPH_CHUNKS_PROCESSED = 15 # 平衡批量效率与容错
